# AutoDiligence — Environment Variables
# Copy this file to .env and fill in your values.

# Required: TinyFish API key
TINYFISH_API_KEY=sk-tinyfish-your-key-here

# Optional: Redis for distributed token vault (leave blank for in-memory)
REDIS_URL=

# Optional: comma-separated allowed CORS origins (default includes Vite dev server)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
